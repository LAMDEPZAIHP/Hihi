-- 🔗 WHITELIST CHECK (GIỮ NGUYÊN)
local WHITELIST_URL = "https://raw.githubusercontent.com/LAMDEPZAIHP/Fox-foxv-whitelish/main/Whitelish_scriptfox"
local function getWhitelist()
    local ok, data = pcall(function() return game:HttpGet(WHITELIST_URL) end)
    if not ok or not data then return {} end
    local list = {}
    for line in data:gmatch("[^\r\n]+") do
        local id = tonumber(line)
        if id then table.insert(list, id) end
    end
    return list
end

local whitelist = getWhitelist()
if not table.find(whitelist, LocalPlayer.UserId) then
    return -- Dừng nếu không có whitelist
end

