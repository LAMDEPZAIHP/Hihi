local function applyOrangeBorder(instance)
    local stroke = Instance.new("UIStroke", instance)
    stroke.Thickness = 2
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    RunService.RenderStepped:Connect(function() 
        stroke.Color = Color3.fromHSV(tick() % 2 / 2, 1, 1) -- Hiệu ứng cầu vồng nhẹ tông cam
    end)
end

local function createBtn(parent, x, y, text, width)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0, width or 235, 0, 32)
    btn.Position = UDim2.new(0, x, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(50, 25, 0)
    btn.TextColor3 = Color3.fromRGB(255, 180, 50)
    btn.Text = text
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    applyOrangeBorder(btn)
    return btn
end

